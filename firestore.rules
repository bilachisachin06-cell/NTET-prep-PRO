rules_version = '2';

/**
 * NTET Prep Pro - Security Rules (Prototyping Mode)
 * Powered by SUGAM ವಿಜ್ಞಾನ
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- USER PROFILE RULES ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // --- ACCESS CONTROL LISTS ---

    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false;
    }

    // --- PUBLIC EXAM CONTENT ---

    match /examDetails/{examDetailId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /syllabi/{syllabusId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /syllabusPoints/{syllabusPointId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /notes/{noteId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /questions/{questionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /testDefinitions/{testDefinitionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // --- USER PRIVATE TEST DATA ---

    match /users/{userId}/testSessions/{testSessionId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);

      match /userAttempts/{userAttemptId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.testSessionId == testSessionId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}
